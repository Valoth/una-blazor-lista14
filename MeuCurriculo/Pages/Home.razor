@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://api.dicebear.com/9.x/adventurer/svg?seed=Aneka"
                     width="120" />
                <h3>Luan Mauricio</h3>
                <p class="text-muted">Supervisor de Tecnologia Pleno</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "AeC",
            Cargo = "Supervisor de Tecnologia Pleno",
            Inicio = "2024",
            Descricao = "Atuação em gestão de time técnico focado em Helpdesk do ambiente de Telemarketing."
        },
        new Experiencia {
            Empresa = "Mc Donald's",
            Cargo = "Técnico de Manutenção",
            Inicio = "2023", Fim = "2024",
            Descricao = "Gestão da manutenção corretiva e preventiva do maquinário vigente das lojas."
        }
    };
}